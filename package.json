{
  "name": "@openfantasymap/lcars-react",
  "version": "0.2.0",
  "description": "React components + hooks for the LCARS design system, wrapping @openfantasymap/lcars-core.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "verify": "node ./scripts/verify.mjs"
  },
  "keywords": [
    "lcars",
    "star-trek",
    "react",
    "components",
    "hooks",
    "ui"
  ],
  "peerDependencies": {
    "@openfantasymap/lcars-core": ">=0.1.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@openfantasymap/lcars-core": ">=0.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^6.7.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openfantasymap/lcars-react.git"
  },
  "homepage": "https://github.com/openfantasymap/lcars-react#readme",
  "bugs": {
    "url": "https://github.com/openfantasymap/lcars-react/issues"
  }
}
